    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "5.15.12",
    "@types/node": "22.10.5",
    "@types/react": "19.2.1",
    "@types/react-dom": "19.2.1",
    "eslint": "9.17.0",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.17",
    "typescript": "5.7.3"
  },
