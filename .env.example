# Runtime mode. Demo is opt-in and must never be enabled with real data.
NEXT_PUBLIC_DEMO_MODE=false
ROUTSIFY_ALLOW_PUBLIC_DEMO=false

# Public application configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Routsify Software
NEXT_PUBLIC_BRAND_COLOR=#379237

# Server-only Supabase configuration
SUPABASE_SERVICE_ROLE_KEY=
# Optional but recommended: stable 32+ character key used to encrypt API keys stored from Ajustes.
ROUTSIFY_SECRETS_ENCRYPTION_KEY=
ROUTSIFY_DEFAULT_ORGANIZATION_ID=
ROUTSIFY_INTERNAL_API_TOKEN=

# Signed public proposal links
PROPOSAL_TOKEN_SECRET=

# Webhook verification
FORM_WEBHOOK_SECRET=
BOOKING_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_SECRET=
HOLDED_WEBHOOK_SECRET=

# Holded integration fallback. Production credentials are entered in Ajustes and encrypted server-side.
HOLDED_API_KEY=
HOLDED_API_BASE_URL=https://api.holded.com/api

# OpenAI OCR fallback. Production credentials are entered in Ajustes and encrypted server-side.
OPENAI_API_KEY=
OPENAI_OCR_MODEL=gpt-5-mini

# Edge Functions / scheduled jobs
SUPABASE_PROJECT_URL=
OUTBOX_WORKER_SECRET=
