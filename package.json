{
  "name": "routsify-software",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run validate:platform && next build",
    "platform:build": "npm run validate:platform && npm run typecheck && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate:mvp": "node scripts/validate-mvp.mjs",
    "validate:booking": "node scripts/validate-booking-api.mjs",
    "validate:holded": "node scripts/validate-holded-v2.mjs",
    "validate:platform": "npm run validate:mvp && npm run validate:booking && npm run validate:holded && node scripts/validate-platform.mjs",
    "test:e2e": "npx --yes @playwright/test@latest test",
    "quality:dead-code": "npx --yes knip@5 --config knip.json",
    "analyze:bundle": "next experimental-analyze --output",
    "db:types": "npx --yes supabase@2 gen types typescript --project-id wphiurjzkxbkakiozgvf --schema public > lib/database.types.ts"
  },
  "dependencies": {
    "@supabase/ssr": "0.7.0",
    "@supabase/supabase-js": "2.110.2",
    "echarts": "6.1.0",
    "lucide-react": "0.468.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "5.15.12",
    "@types/node": "22.10.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.17.0",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.17",
    "typescript": "5.7.3"
  },
  "overrides": {
    "postcss": "8.5.17"
  }
}
