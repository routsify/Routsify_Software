{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "ignoreCommand": "test -n \"$VERCEL_GIT_COMMIT_REF\" && test \"$VERCEL_GIT_COMMIT_REF\" != main",
  "crons": [
    {
      "path": "/api/cron/operations",
      "schedule": "15 5 * * *"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "internal-mvp-v11-validation": false,
      "internal-mvp-v11-payload-final": false
    }
  }
}
