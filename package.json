{
  "name": "routsify-software",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && opennextjs-cloudflare build --skipNextBuild",
    "build:next": "next build",
    "build:cloudflare": "next build && opennextjs-cloudflare build --skipNextBuild",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "platform:build": "npm run validate:platform && npm run typecheck && npm run build:next",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate:mvp": "node scripts/validate-mvp.mjs",
    "validate:platform": "npm run validate:mvp && node scripts/validate-platform.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "0.7.0",
    "@supabase/supabase-js": "2.48.1",
    "echarts": "5.6.0",
    "lucide-react": "0.468.0",
    "next": "16.2.1",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "5.15.12",
    "@opennextjs/cloudflare": "1.20.1",
    "@types/node": "22.10.5",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "eslint": "9.17.0",
    "eslint-config-next": "16.2.1",
    "typescript": "5.7.3",
    "wrangler": "4.110.0"
  }
}