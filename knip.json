{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "proxy.ts",
    "scripts/**/*.{js,mjs,cjs,ts}"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "scripts/**/*.{js,mjs,cjs,ts}",
    "*.{ts,tsx,js,mjs,cjs}"
  ],
  "ignore": [
    ".next/**",
    "supabase/migrations/**",
    "playwright-report/**",
    "test-results/**"
  ],
  "ignoreDependencies": [
    "@netlify/plugin-nextjs"
  ]
}
